# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smart_inventory_v3"

# CORS — comma-separated frontend origins
CORS_ORIGIN=http://localhost:5173

# JWT — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-production-secret
JWT_EXPIRES_IN=7d

# SMTP (password reset — dev logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@smartinventory.com

# Frontend URL (for password reset links)
APP_URL=http://localhost:5173

# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smart_inventory_v3"

# CORS — frontend URL(s). Comma-separated for multiple origins:
#   Local:    http://localhost:5173
#   Cloud:    https://your-app.vercel.app,https://your-tunnel.trycloudflare.com
#   Combined: http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT — generate a secure secret via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-production-secret
JWT_EXPIRES_IN=7d

# SMTP (for password reset — dev mode logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@smartinventory.com

# Frontend URL (for password reset links)
APP_URL=http://localhost:5173

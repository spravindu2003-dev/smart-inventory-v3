# ============================================================
# LOCAL DEVELOPMENT (works out of the box):
#   Frontend: npm run dev  → reads .env.development
#   Backend:  npm run dev  → runs on localhost:5000
# ============================================================
# VITE_API_URL=http://localhost:5000/api
#
# ============================================================
# PRODUCTION (Vercel):
#   Set VITE_API_URL in Vercel Dashboard → Environment Variables
#   Value: https://your-deployed-backend.com/api
# ============================================================
